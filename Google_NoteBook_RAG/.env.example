# --- Qdrant (Vector DB) ---
# Get a free cluster at https://cloud.qdrant.io
QDRANT_URL=https://YOUR-CLUSTER.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

# --- Jina AI (Embeddings) ---
# Free tier (1M tokens) at https://jina.ai/?sui=apikey
JINA_API_KEY=jina_xxx

# --- OpenRouter (LLM) ---
# Free models available at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx
# Model id. Default uses a free Google Gemma 4 model.
# If this gets rate-limited or removed, swap for any working free model:
#   google/gemma-4-31b-it:free               (default — Google instruct, ~31B)
#   meta-llama/llama-3.3-70b-instruct:free   (reliable, larger)
#   qwen/qwen3-next-80b-a3b-instruct:free    (Qwen 3, MoE)
#   z-ai/glm-4.5-air:free                    (fast MoE)
#   nvidia/nemotron-nano-9b-v2:free          (small + fast)
# Full list: https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=google/gemma-4-31b-it:free
