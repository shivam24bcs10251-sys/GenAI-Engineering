# --- Qdrant (Vector DB) ---
# Get a free cluster at https://cloud.qdrant.io
QDRANT_URL=https://YOUR-CLUSTER.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

# --- Jina AI (Embeddings) ---
# Free tier (1M tokens) at https://jina.ai/?sui=apikey
JINA_API_KEY=jina_xxx

# --- LLM provider ---
# Choose one: "openrouter" (default) or "groq".
# Groq has a separate free quota pool from OpenRouter, so when OpenRouter free
# models return 429 (heavily shared), Groq usually still works.
LLM_PROVIDER=groq

# --- Groq (recommended free LLM) ---
# Free key at https://console.groq.com/keys (no credit card)
GROQ_API_KEY=gsk_xxx
# Good free Groq models for RAG:
#   llama-3.3-70b-versatile      (default — strong, fast)
#   llama-3.1-8b-instant         (smaller, even faster)
#   qwen/qwen3-32b               (good follower)
#   gemma2-9b-it                 (small Google instruct)
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenRouter (only used if LLM_PROVIDER=openrouter) ---
# Free models at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx
# Currently working free models (May 2026):
#   meta-llama/llama-3.3-70b-instruct:free
#   qwen/qwen3-next-80b-a3b-instruct:free
#   z-ai/glm-4.5-air:free
#   nvidia/nemotron-nano-9b-v2:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
